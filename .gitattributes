# --- Git LFS : gestion des fichiers binaires lourds (si vous choisissez de les committer) ---
# Activer une seule fois sur la machine :  git lfs install
*.pt   filter=lfs diff=lfs merge=lfs -text
*.pth  filter=lfs diff=lfs merge=lfs -text
*.zip  filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text
*.gz   filter=lfs diff=lfs merge=lfs -text

# --- Fichiers binaires : interdire toute conversion de fins de ligne (anti-corruption) ---
*.pdf  binary
*.docx binary
*.png  binary

# --- Les notebooks sont du texte (JSON) : pas de normalisation de fins de ligne ---
*.ipynb -text
